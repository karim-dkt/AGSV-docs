<?xml version="1.0" encoding="UTF-8"?>
<diagram type="usecase" name="utilisateur_standard_2"
         title="Cas d'utilisation — Utilisateur standard (2/2) : Crédits &amp; Créances · Clients · Stock &amp; Pertes"
         part="2 of 2" see-also="utilisateur_standard_1.xml">

  <actors>
    <actor id="U" name="Utilisateur (Admin / Vendeur)"/>
  </actors>

  <system name="Système AGSV">

    <package name="Crédits et Créances">
      <usecase id="UC_CREANCE"      name="Enregistrer une créance"/>
      <usecase id="UC_PAY_PARTIEL"  name="Enregistrer un paiement partiel"/>
      <usecase id="UC_CREDIT"       name="Consulter les crédits"/>
      <usecase id="UC_SEND_CREANCE" name="Envoyer infos créances"/>
      <usecase id="UC_SEARCH_VENTE" name="Rechercher la vente"/>
      <usecase id="UC_MODE_PAY"     name="Choisir mode de paiement"/>
    </package>

    <package name="Clients">
      <usecase id="UC_CLIENT_ADD"    name="Enregistrer un client"/>
      <usecase id="UC_CLIENT"        name="Consulter les clients"/>
      <usecase id="UC_SEARCH_CLIENT" name="Rechercher un client"/>
    </package>

    <package name="Stock et Pertes">
      <usecase id="UC_PROD_FICHE" name="Consulter fiche produit"/>
      <usecase id="UC_PERTE"      name="Déclarer une perte"/>
    </package>

  </system>

  <relationships>
    <!-- Associations acteur -->
    <association actor="U" usecase="UC_CREANCE"/>
    <association actor="U" usecase="UC_PAY_PARTIEL"/>
    <association actor="U" usecase="UC_CREDIT"/>
    <association actor="U" usecase="UC_CLIENT_ADD"/>
    <association actor="U" usecase="UC_CLIENT"/>
    <association actor="U" usecase="UC_PROD_FICHE"/>
    <association actor="U" usecase="UC_PERTE"/>

    <!-- Crédits — include -->
    <include base="UC_PAY_PARTIEL" inclusion="UC_SEARCH_VENTE"/>
    <include base="UC_CREANCE"     inclusion="UC_SEND_CREANCE"/>

    <!-- Crédits — extend -->
    <extend base="UC_MODE_PAY" extension="UC_CREANCE"/>

    <!-- Clients — include -->
    <include base="UC_CLIENT_ADD" inclusion="UC_SEARCH_CLIENT"/>
  </relationships>

</diagram>