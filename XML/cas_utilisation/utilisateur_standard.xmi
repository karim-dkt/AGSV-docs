<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.1"
    xmlns:xmi="http://schema.omg.org/spec/XMI/2.1"
    xmlns:uml="http://schema.omg.org/spec/UML/2.1">

  <xmi:Documentation exporter="Enterprise Architect" exporterVersion="6.5"/>

  <uml:Model xmi:type="uml:Model" name="EA_Model" visibility="public">

    <packagedElement xmi:type="uml:Package"
                     xmi:id="{10000000-0000-0000-0000-000000000001}"
                     name="Utilisateur Standard - Fonctions communes"
                     visibility="public">

      <!-- ============================================================ -->
      <!-- ACTEUR                                                        -->
      <!-- ============================================================ -->
      <packagedElement xmi:type="uml:Actor"
                       xmi:id="{10000000-0000-0000-0000-000000000010}"
                       name="Utilisateur (Admin / Vendeur)"
                       visibility="public"/>

      <!-- ============================================================ -->
      <!-- PACKAGE : Authentification                                    -->
      <!-- ============================================================ -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{20000000-0000-0000-0000-000000000001}"
                       name="Authentification"
                       visibility="public">

        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000001}"
                         name="Se connecter"
                         visibility="public"/>

        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000002}"
                         name="Modifier mot de passe"
                         visibility="public"/>

        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000003}"
                         name="Réinitialiser mot de passe"
                         visibility="public"/>

        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000004}"
                         name="Se déconnecter"
                         visibility="public"/>

      </packagedElement>

      <!-- ============================================================ -->
      <!-- PACKAGE : Tableau de bord                                    -->
      <!-- ============================================================ -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{20000000-0000-0000-0000-000000000002}"
                       name="Tableau de bord"
                       visibility="public">

        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000005}"
                         name="Consulter le tableau de bord"
                         visibility="public"/>

      </packagedElement>

      <!-- ============================================================ -->
      <!-- PACKAGE : Ventes                                             -->
      <!-- ============================================================ -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{20000000-0000-0000-0000-000000000003}"
                       name="Ventes"
                       visibility="public">

        <!-- UC_VENTE : include MODE_PAY + extend CMD -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000006}"
                         name="Enregistrer une vente"
                         visibility="public">
          <include xmi:type="uml:Include"
                   xmi:id="{40000000-0000-0000-0000-000000000001}"
                   name=""
                   addition="{30000000-0000-0000-0000-000000000009}"/>
          <extend xmi:type="uml:Extend"
                  xmi:id="{50000000-0000-0000-0000-000000000007}"
                  name=""
                  extendedCase="{30000000-0000-0000-0000-000000000019}"/>
        </packagedElement>

        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000007}"
                         name="Consulter les ventes"
                         visibility="public"/>

        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000008}"
                         name="Consulter le détail d'une vente"
                         visibility="public"/>

        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000009}"
                         name="Choisir mode de paiement"
                         visibility="public"/>

        <!-- UC_PAY_CASH : généralisation vers MODE_PAY -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000010}"
                         name="Par espèces"
                         visibility="public">
          <generalization xmi:type="uml:Generalization"
                          xmi:id="{60000000-0000-0000-0000-000000000001}"
                          general="{30000000-0000-0000-0000-000000000009}"/>
        </packagedElement>

        <!-- UC_PAY_MOBILE : généralisation vers MODE_PAY -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000011}"
                         name="Par Mobile Money"
                         visibility="public">
          <generalization xmi:type="uml:Generalization"
                          xmi:id="{60000000-0000-0000-0000-000000000002}"
                          general="{30000000-0000-0000-0000-000000000009}"/>
        </packagedElement>

        <!-- UC_PAY_LETTRE : généralisation vers MODE_PAY -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000012}"
                         name="Par lettre d'échange"
                         visibility="public">
          <generalization xmi:type="uml:Generalization"
                          xmi:id="{60000000-0000-0000-0000-000000000003}"
                          general="{30000000-0000-0000-0000-000000000009}"/>
        </packagedElement>

        <!-- UC_FACTURE : extend UC_VENTE -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000013}"
                         name="Générer facture (PDF)"
                         visibility="public">
          <extend xmi:type="uml:Extend"
                  xmi:id="{50000000-0000-0000-0000-000000000001}"
                  name=""
                  extendedCase="{30000000-0000-0000-0000-000000000006}"/>
        </packagedElement>

        <!-- UC_PRINT_FACTURE : extend UC_FACTURE -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{30000000-0000-0000-0000-000000000014}"
                         name="Imprimer la facture"
                         visibility="public">
          <extend xmi:type="uml:Extend"
                  xmi:id="{50000000-0000-0000-0000-000000000002}"
                  name=""
                  extendedCase="{30000000-0000-0000-0000-000000000013}"/>
        </packagedElement>

        <!-- UC_SEND_FACTURE : extend UC_FACTURE -->
        <packagedElement xmi:type="uml:UseCase"
