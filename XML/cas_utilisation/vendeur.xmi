<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.1"
    xmlns:xmi="http://schema.omg.org/spec/XMI/2.1"
    xmlns:uml="http://schema.omg.org/spec/UML/2.1">

  <xmi:Documentation exporter="Enterprise Architect" exporterVersion="6.5"/>

  <uml:Model xmi:type="uml:Model" name="EA_Model" visibility="public">

    <packagedElement xmi:type="uml:Package"
                     xmi:id="{CB100000-0000-0000-0000-000000000001}"
                     name="Vendeur"
                     visibility="public">

      <!-- ACTEUR -->
      <packagedElement xmi:type="uml:Actor"
                       xmi:id="{CA100000-0000-0000-0000-000000000001}"
                       name="Vendeur"
                       visibility="public"/>

      <!-- PACKAGE : Fonctions communes (héritées) -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{CB100000-0000-0000-0000-000000000002}"
                       name="Fonctions communes (héritées)"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000001}"
                         name="Voir utilisateur_standard"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Produits (lecture seule) -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{CB100000-0000-0000-0000-000000000003}"
                       name="Produits (lecture seule)"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000002}"
                         name="Consulter les produits de son dépôt"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000003}"
                         name="Voir les niveaux de stock de son dépôt"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Inventaire -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{CB100000-0000-0000-0000-000000000004}"
                       name="Inventaire"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000004}"
                         name="Faire un inventaire"
                         visibility="public"/>
        <!-- UC_PERTE : extend UC_INV -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000005}"
                         name="Déclarer une perte"
                         visibility="public">
          <extend xmi:type="uml:Extend"
                  xmi:id="{CE100000-0000-0000-0000-000000000001}"
                  name=""
                  extendedCase="{CC100000-0000-0000-0000-000000000004}"/>
        </packagedElement>
      </packagedElement>

      <!-- PACKAGE : Créances -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{CB100000-0000-0000-0000-000000000005}"
                       name="Créances"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000006}"
                         name="Suivre les créances de son dépôt"
                         visibility="public"/>
        <!-- UC_RELEVE : extend UC_CREANCES -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000007}"
                         name="Générer relevé de dettes"
                         visibility="public">
          <extend xmi:type="uml:Extend"
                  xmi:id="{CE100000-0000-0000-0000-000000000002}"
                  name=""
                  extendedCase="{CC100000-0000-0000-0000-000000000006}"/>
        </packagedElement>
        <!-- UC_RELEVE_MAIL : extend UC_RELEVE -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000008}"
                         name="Envoyer relevé par email"
                         visibility="public">
          <extend xmi:type="uml:Extend"
                  xmi:id="{CE100000-0000-0000-0000-000000000003}"
                  name=""
                  extendedCase="{CC100000-0000-0000-0000-000000000007}"/>
        </packagedElement>
      </packagedElement>

      <!-- PACKAGE : Performances -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{CB100000-0000-0000-0000-000000000006}"
                       name="Performances"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000009}"
                         name="Consulter ses performances"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Clients -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{CB100000-0000-0000-0000-000000000007}"
                       name="Clients"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000010}"
                         name="Consulter les clients du dépôt"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{CC100000-0000-0000-0000-000000000011}"
                         name="Ajouter un client"
                         visibility="public"/>
      </packagedElement>

