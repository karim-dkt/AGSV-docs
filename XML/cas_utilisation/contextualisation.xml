<?xml version="1.0" encoding="UTF-8"?>
<diagram type="usecase" name="contextualisation"
         title="Diagramme de contextualisation — Hiérarchie des acteurs et relations avec le système AGSV">

  <actors>
    <actor id="US"    name="Utilisateur Standard" stereotype="abstract"/>
    <actor id="V"     name="Vendeur"/>
    <actor id="A"     name="Administrateur"/>
    <actor id="AP"    name="Administrateur Principal (AP)"/>
    <actor id="C"     name="Client" stereotype="external"/>
    <actor id="MAIL"  name="Serveur Mail"      stereotype="external"/>
    <actor id="SMS"   name="Serveur SMS"        stereotype="external" status="not-implemented"/>
    <actor id="WA"    name="Serveur WhatsApp"   stereotype="external" status="not-implemented"/>
    <actor id="PRINT" name="Imprimante"         stereotype="external"/>
  </actors>

  <system name="Système AGSV">
    <usecase id="UC_AUTH"    name="Authentification"/>
    <usecase id="UC_DASH"    name="Tableau de bord"/>
    <usecase id="UC_VENTE"   name="Ventes et Commandes"/>
    <usecase id="UC_CREDIT"  name="Crédits et Créances"/>
    <usecase id="UC_LETTRE"  name="Lettres d'échange"/>
    <usecase id="UC_PROD"    name="Gestion des produits"/>
    <usecase id="UC_STOCK"   name="Stock et Approvisionnements"/>
    <usecase id="UC_INV"     name="Inventaires et Pertes"/>
    <usecase id="UC_CLIENTS" name="Clients et Fournisseurs"/>
    <usecase id="UC_USER"    name="Gestion des utilisateurs"/>
    <usecase id="UC_DEPOT"   name="Gestion des dépôts"/>
    <usecase id="UC_ENT"     name="Gestion multi-entreprises"/>
    <usecase id="UC_RAPPORT" name="Rapports et Exports"/>
    <usecase id="UC_NOTIF"   name="Notifications et Alertes"/>
  </system>

  <relationships>
    <!-- Hiérarchie des acteurs -->
    <generalization child="V"  parent="US"/>
    <generalization child="A"  parent="US"/>
    <generalization child="AP" parent="A"/>

    <!-- Utilisateur Standard — fonctions communes -->
    <association actor="US" usecase="UC_AUTH"/>
    <association actor="US" usecase="UC_DASH"/>
    <association actor="US" usecase="UC_VENTE"/>
    <association actor="US" usecase="UC_CREDIT"/>
    <association actor="US" usecase="UC_CLIENTS"/>
    <association actor="US" usecase="UC_INV"/>

    <!-- Vendeur — accès supplémentaires (limités au dépôt) -->
    <association actor="V" usecase="UC_PROD"/>

    <!-- Administrateur — accès supplémentaires -->
    <association actor="A" usecase="UC_LETTRE"/>
    <association actor="A" usecase="UC_PROD"/>
    <association actor="A" usecase="UC_STOCK"/>
    <association actor="A" usecase="UC_USER"/>
    <association actor="A" usecase="UC_DEPOT"/>
    <association actor="A" usecase="UC_RAPPORT"/>
    <association actor="A" usecase="UC_NOTIF"/>

    <!-- Administrateur Principal — accès supplémentaires -->
    <association actor="AP" usecase="UC_ENT"/>
    <association actor="AP" usecase="UC_NOTIF"/>

    <!-- Client — bénéficiaire externe -->
    <dependency from="C" to="UC_VENTE" stereotype="bénéficiaire"/>

    <!-- Systèmes externes notifiés -->
    <dependency from="UC_NOTIF" to="MAIL"  stereotype="notifie"/>
    <dependency from="UC_NOTIF" to="SMS"   stereotype="notifie" status="not-implemented"/>
    <dependency from="UC_NOTIF" to="WA"    stereotype="notifie" status="not-implemented"/>
    <dependency from="UC_VENTE" to="PRINT" stereotype="impression"/>
  </relationships>

</diagram>