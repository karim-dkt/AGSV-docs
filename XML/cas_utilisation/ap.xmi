<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.1"
    xmlns:xmi="http://schema.omg.org/spec/XMI/2.1"
    xmlns:uml="http://schema.omg.org/spec/UML/2.1">

  <xmi:Documentation exporter="Enterprise Architect" exporterVersion="6.5"/>

  <uml:Model xmi:type="uml:Model" name="EA_Model" visibility="public">

    <packagedElement xmi:type="uml:Package"
                     xmi:id="{BB100000-0000-0000-0000-000000000001}"
                     name="Administrateur Principal (AP)"
                     visibility="public">

      <!-- ACTEUR -->
      <packagedElement xmi:type="uml:Actor"
                       xmi:id="{BA100000-0000-0000-0000-000000000001}"
                       name="Administrateur Principal (AP)"
                       visibility="public"/>

      <!-- PACKAGE : Fonctions héritées -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{BB100000-0000-0000-0000-000000000002}"
                       name="Fonctions héritées (Admin + Standard)"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000001}"
                         name="Voir admin"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Gestion multi-entreprises -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{BB100000-0000-0000-0000-000000000003}"
                       name="Gestion multi-entreprises"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000002}"
                         name="Créer une entreprise"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000003}"
                         name="Modifier une entreprise"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000004}"
                         name="Activer / désactiver une entreprise"
                         visibility="public"/>
        <!-- UC_ENT_SELECT : include UC_DASH -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000005}"
                         name="Changer d'entreprise active (sélection dans le header)"
                         visibility="public">
          <include xmi:type="uml:Include"
                   xmi:id="{BD100000-0000-0000-0000-000000000001}"
                   name=""
                   addition="{BC100000-0000-0000-0000-000000000007}"/>
        </packagedElement>
        <!-- UC_ENT_ASSIGN : extend UC_ENT_ADD -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000006}"
                         name="Attribuer des admins à une entreprise"
                         visibility="public">
          <extend xmi:type="uml:Extend"
                  xmi:id="{BE100000-0000-0000-0000-000000000001}"
                  name=""
                  extendedCase="{BC100000-0000-0000-0000-000000000002}"/>
        </packagedElement>
      </packagedElement>

      <!-- PACKAGE : Supervision et Tableau de bord -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{BB100000-0000-0000-0000-000000000004}"
                       name="Supervision et Tableau de bord"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000007}"
                         name="Consulter le tableau de bord multi-entreprises"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000008}"
                         name="Comparer les performances entre entreprises"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000009}"
                         name="Superviser toutes les activités (approvisionnements, pertes...)"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Notifications -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{BB100000-0000-0000-0000-000000000005}"
                       name="Notifications"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000010}"
                         name="Recevoir des notifications d'activité admin"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{BC100000-0000-0000-0000-000000000011}"
                         name="Consulter les alertes de stock"
                         visibility="public"/>
      </packagedElement>

