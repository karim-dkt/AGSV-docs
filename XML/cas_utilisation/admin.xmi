<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.1"
    xmlns:xmi="http://schema.omg.org/spec/XMI/2.1"
    xmlns:uml="http://schema.omg.org/spec/UML/2.1">

  <xmi:Documentation exporter="Enterprise Architect" exporterVersion="6.5"/>

  <uml:Model xmi:type="uml:Model" name="EA_Model" visibility="public">

    <packagedElement xmi:type="uml:Package"
                     xmi:id="{AB100000-0000-0000-0000-000000000001}"
                     name="Administrateur"
                     visibility="public">

      <!-- ACTEURS -->
      <packagedElement xmi:type="uml:Actor"
                       xmi:id="{AA100000-0000-0000-0000-000000000001}"
                       name="Administrateur"
                       visibility="public"/>
      <packagedElement xmi:type="uml:Actor"
                       xmi:id="{AA100000-0000-0000-0000-000000000002}"
                       name="Serveur Mail"
                       visibility="public"/>

      <!-- PACKAGE : Fonctions communes (héritées) -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000002}"
                       name="Fonctions communes (héritées)"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000001}"
                         name="Voir utilisateur_standard"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Produits et Catégories -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000003}"
                       name="Produits et Catégories"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000002}"
                         name="Créer un produit"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000003}"
                         name="Modifier un produit"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000004}"
                         name="Désactiver / Réactiver un produit"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000005}"
                         name="Gérer les catégories"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Stock et Approvisionnement -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000004}"
                       name="Stock et Approvisionnement"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000006}"
                         name="Enregistrer un approvisionnement"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000007}"
                         name="Consulter l'historique des approvisionnements"
                         visibility="public"/>
        <!-- UC_NOTIF_CLIENT : extend UC_APPRO -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000008}"
                         name="Notifier le client"
                         visibility="public">
          <extend xmi:type="uml:Extend"
                  xmi:id="{AE100000-0000-0000-0000-000000000001}"
                  name=""
                  extendedCase="{AC100000-0000-0000-0000-000000000006}"/>
        </packagedElement>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000009}"
                         name="Consulter les mouvements de stock"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Inventaire -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000005}"
                       name="Inventaire"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000010}"
                         name="Consulter les inventaires (en attente)"
                         visibility="public"/>
        <!-- UC_INV_VAL : include UC_STOCK -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000011}"
                         name="Valider un inventaire"
                         visibility="public">
          <include xmi:type="uml:Include"
                   xmi:id="{AD100000-0000-0000-0000-000000000001}"
                   name=""
                   addition="{AC100000-0000-0000-0000-000000000009}"/>
        </packagedElement>
        <!-- UC_INV_REJ : include UC_STOCK -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000012}"
                         name="Refuser un inventaire"
                         visibility="public">
          <include xmi:type="uml:Include"
                   xmi:id="{AD100000-0000-0000-0000-000000000002}"
                   name=""
                   addition="{AC100000-0000-0000-0000-000000000009}"/>
        </packagedElement>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000013}"
                         name="Consulter l'historique des inventaires"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Pertes -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000006}"
                       name="Pertes"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000014}"
                         name="Déclarer une perte (côté admin)"
                         visibility="public"/>
        <!-- UC_PERTE_VAL : include UC_STOCK -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000015}"
                         name="Valider une perte"
                         visibility="public">
          <include xmi:type="uml:Include"
                   xmi:id="{AD100000-0000-0000-0000-000000000003}"
                   name=""
                   addition="{AC100000-0000-0000-0000-000000000009}"/>
        </packagedElement>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000016}"
                         name="Refuser une perte"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000017}"
                         name="Consulter l'historique des pertes"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Clients et Fournisseurs -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000007}"
                       name="Clients et Fournisseurs"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000018}"
                         name="Gérer les clients (CRUD)"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000019}"
                         name="Enregistrer un fournisseur"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000020}"
                         name="Modifier un fournisseur"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000021}"
                         name="Désactiver / Réactiver un fournisseur"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Dépôts -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000008}"
                       name="Dépôts"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000022}"
                         name="Ajouter un dépôt"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000023}"
                         name="Modifier un dépôt"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000024}"
                         name="Activer / désactiver un dépôt"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Utilisateurs -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000009}"
                       name="Utilisateurs"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000025}"
                         name="Enregistrer un vendeur ou administrateur"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000026}"
                         name="Modifier un utilisateur"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000027}"
                         name="Activer / désactiver un vendeur"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000028}"
                         name="Retirer / désactiver un vendeur"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Finances -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000010}"
                       name="Finances"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000029}"
                         name="Gérer les lettres d'échange"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000030}"
                         name="Suivre les créances de l'entreprise"
                         visibility="public"/>
        <!-- UC_RELEVE : extend UC_CREANCES -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000031}"
                         name="Générer relevé de dettes"
                         visibility="public">
          <extend xmi:type="uml:Extend"
                  xmi:id="{AE100000-0000-0000-0000-000000000002}"
                  name=""
                  extendedCase="{AC100000-0000-0000-0000-000000000030}"/>
        </packagedElement>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000032}"
                         name="Enregistrer un paiement sur crédit"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Rapports et Exports -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000011}"
                       name="Rapports et Exports"
                       visibility="public">
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000033}"
                         name="Visualiser tous les rapports"
                         visibility="public"/>
        <!-- UC_EXPORT : include UC_RAPPORT -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000034}"
                         name="Exporter un rapport (PDF / Excel)"
                         visibility="public">
          <include xmi:type="uml:Include"
                   xmi:id="{AD100000-0000-0000-0000-000000000004}"
                   name=""
                   addition="{AC100000-0000-0000-0000-000000000033}"/>
        </packagedElement>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000035}"
                         name="Comparer les performances dans une entreprise"
                         visibility="public"/>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000036}"
                         name="Importer des données"
                         visibility="public"/>
      </packagedElement>

      <!-- PACKAGE : Alertes -->
      <packagedElement xmi:type="uml:Package"
                       xmi:id="{AB100000-0000-0000-0000-000000000012}"
                       name="Alertes"
                       visibility="public">
        <!-- UC_ALERT : include UC_STOCK -->
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000037}"
                         name="Alerter au seuil de stock atteint"
                         visibility="public">
          <include xmi:type="uml:Include"
                   xmi:id="{AD100000-0000-0000-0000-000000000005}"
                   name=""
                   addition="{AC100000-0000-0000-0000-000000000009}"/>
        </packagedElement>
        <packagedElement xmi:type="uml:UseCase"
                         xmi:id="{AC100000-0000-0000-0000-000000000038}"
                         name="Consulter les alertes"
                         visibility="public"/>
      </packagedElement>

