<?xml version="1.0" encoding="UTF-8"?>
<diagram type="usecase" name="ap"
         title="Cas d'utilisation — Administrateur Principal (AP)"
         see-also="admin.xml utilisateur_standard_1.xml utilisateur_standard_2.xml">

  <actors>
    <actor id="AP" name="Administrateur Principal (AP)"/>
  </actors>

  <system name="Système AGSV">

    <package name="Fonctions héritées (Admin + Standard)">
      <usecase id="UC_ADMIN" name="Voir admin.puml"/>
    </package>

    <package name="Gestion multi-entreprises">
      <usecase id="UC_ENT_ADD"    name="Créer une entreprise"/>
      <usecase id="UC_ENT_EDIT"   name="Modifier une entreprise"/>
      <usecase id="UC_ENT_ACT"    name="Activer / désactiver une entreprise"/>
      <usecase id="UC_ENT_SELECT" name="Changer d'entreprise active (sélection dans le header)"/>
      <usecase id="UC_ENT_ASSIGN" name="Attribuer des admins à une entreprise"/>
    </package>

    <package name="Supervision et Tableau de bord">
      <usecase id="UC_DASH"        name="Consulter le tableau de bord multi-entreprises"/>
      <usecase id="UC_PERF_COMPARE" name="Comparer les performances entre entreprises"/>
      <usecase id="UC_SUPERVISION"  name="Superviser toutes les activités (approvisionnements, pertes…)"/>
    </package>

    <package name="Notifications">
      <usecase id="UC_NOTIF" name="Recevoir des notifications d'activité admin"/>
      <usecase id="UC_ALERT" name="Consulter les alertes de stock"/>
    </package>

  </system>

  <relationships>
    <!-- Associations acteur -->
    <association actor="AP" usecase="UC_ADMIN"/>
    <association actor="AP" usecase="UC_ENT_ADD"/>
    <association actor="AP" usecase="UC_ENT_EDIT"/>
    <association actor="AP" usecase="UC_ENT_ACT"/>
    <association actor="AP" usecase="UC_ENT_SELECT"/>
    <association actor="AP" usecase="UC_ENT_ASSIGN"/>
    <association actor="AP" usecase="UC_DASH"/>
    <association actor="AP" usecase="UC_PERF_COMPARE"/>
    <association actor="AP" usecase="UC_SUPERVISION"/>
    <association actor="AP" usecase="UC_NOTIF"/>
    <association actor="AP" usecase="UC_ALERT"/>

    <!-- Gestion multi-entreprises — include et extend -->
    <include base="UC_DASH"    inclusion="UC_ENT_SELECT"/>
    <extend  base="UC_ENT_ADD" extension="UC_ENT_ASSIGN"/>
  </relationships>

</diagram>